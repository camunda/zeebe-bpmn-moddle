{
  "name": "zeebe-bpmn-moddle",
  "version": "1.16.0",
  "description": "Zeebe moddle extensions for BPMN 2.0",
  "scripts": {
    "all": "run-s lint generate-types test",
    "lint": "eslint .",
    "generate-types": "moddle-generate-types --index dist/index.d.ts resources/zeebe.json dist/zeebe.d.ts",
    "prepublishOnly": "run-s generate-types",
    "dev": "npm test -- --watch",
    "test": "mocha -r ./test/expect --reporter=spec --recursive test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/camunda/zeebe-bpmn-moddle"
  },
  "keywords": [
    "bpmn",
    "moddle",
    "bpmn20",
    "zeebe",
    "meta-model"
  ],
  "author": {
    "name": "Maciej Barelkowski",
    "url": "https://github.com/barmac"
  },
  "contributors": [
    {
      "name": "bpmn.io contributors",
      "url": "https://github.com/bpmn-io"
    }
  ],
  "license": "MIT",
  "devDependencies": {
    "@bpmn-io/moddle-types-generator": "^0.2.0",
    "bpmn-moddle": "^10.0.0",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "eslint-plugin-bpmn-io": "^2.2.0",
    "min-dash": "^5.0.0",
    "mocha": "^11.7.6",
    "npm-run-all": "^4.1.2",
    "xsd-schema-validator": "^0.11.0"
  },
  "peerDependencies": {
    "moddle": ">=8.2.0"
  },
  "files": [
    "resources",
    "dist"
  ],
  "types": "dist/index.d.ts",
  "allowScripts": {
    "xsd-schema-validator@0.11.0": true
  }
}
